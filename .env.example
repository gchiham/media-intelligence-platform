# Copiar a .env y completar. Nunca commitear .env real (ya esta en .gitignore).
#
# Este archivo sirve para dos escenarios distintos -- lee la seccion que
# corresponda:
#   - DESARROLLO LOCAL: corriendo `uvicorn` directo en tu maquina (no en
#     Docker), contra el Postgres que levanta `docker compose up postgres`.
#   - PRODUCCION (EC2): corriendo TODO via `docker compose up -d`
#     (backend + postgres + nginx). Ver docs/DEPLOYMENT.md.

# =====================================================================
# PostgreSQL -- usado por el servicio `postgres` de docker-compose.yml
# =====================================================================
POSTGRES_DB=media_intelligence
POSTGRES_USER=postgres
# Password real y fuerte en produccion -- nunca "postgres". Genera uno con
# `openssl rand -base64 24`, por ejemplo.
POSTGRES_PASSWORD=changeme
# Puerto expuesto al host para acceso administrativo (psql, backups) --
# el backend habla con Postgres por la red interna de Docker, no por esto.
POSTGRES_HOST_PORT=5433

# =====================================================================
# Backend (FastAPI / SQLAlchemy)
# =====================================================================
#
# DESARROLLO LOCAL (backend corriendo fuera de Docker, contra el Postgres
# expuesto en POSTGRES_HOST_PORT):
DATABASE_URL=postgresql+psycopg://postgres:changeme@localhost:5433/media_intelligence
#
# PRODUCCION (backend corriendo DENTRO de docker compose): no se usa esta
# variable directamente -- docker-compose.yml arma DATABASE_URL solo a
# partir de POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB, apuntando al
# servicio `postgres` por su nombre de red interna. No hace falta duplicarla
# aqui para produccion.

# Claude es el LLM primario de segmentacion; OpenAI es el respaldo que se usa
# solo si Claude agota sus reintentos (ver AIProviderWithFallback).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Directorio donde LocalFileRecordingResolver busca words.json + audio de
# cada Grabacion (ver src/modules/pipeline/resolvers.py y docs/API.md).
# En Docker esto se monta desde ./data (ver docker-compose.yml).
LOCAL_MEDIA_DIR=./data/recordings

# =====================================================================
# Nginx -- solo aplica en produccion (docker compose up -d)
# =====================================================================
# Puerto HTTP publico de la instancia.
HTTP_PORT=80
